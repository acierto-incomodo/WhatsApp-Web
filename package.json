{
  "name": "whatsapp-web",
  "version": "1.1.2",
  "description": "Cliente de WhatsApp Web hecho con Electron",
  "main": "main.js",
  "author": "StormGamesStudios",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "electron-log": "^5.4.3"
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.stormgamesstudios.whatsapp",
    "productName": "WhatsApp Web",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "icons/icon.ico",
        "to": "icon.ico"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "TU_USUARIO",
        "repo": "whatsapp-electron"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "category": "Network",
      "icon": "icons",
      "maintainer": "StormGamesStudios <meliodas.aitor@gmail.com>",
      "synopsis": "Cliente no oficial de WhatsApp Web",
      "description": "Aplicación ligera basada en Electron que abre WhatsApp Web y guarda tus datos de sesión localmente."
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
